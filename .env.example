# Smart City Crisis Management v1.0 — copy to .env

# --- Default: NVIDIA cloud LLM (per-agent models on same API) ---
LLM_PROFILE=multimodel
NIM_CLOUD_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=nvapi-...

# --- Optional: assign specific agents to local NIM (edit configs/llm/multimodel.yaml) ---
# NIM_LOCAL_BASE_URL=http://127.0.0.1:8000/v1

# Offline only: pytest / scripted demo without API calls
# CRISIS_USE_MOCK_LLM=true

# --- API / UI ---
API_HOST=127.0.0.1
API_PORT=8080
API_BASE_URL=http://127.0.0.1:8080
# Chainlit UI (make start)
CHAINLIT_URL=http://127.0.0.1:7860
SIMULATION_MODE=true
LOG_LEVEL=INFO

# --- Langfuse self-hosted (optional) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# --- Database (optional; v1.0 uses in-memory store) ---
# DATABASE_URL=postgresql://crisis:crisis@localhost:5432/crisis

# --- Optional local-only profile (air-gap / no cloud) ---
# LLM_PROFILE=local
# NIM_LOCAL_BASE_URL=http://127.0.0.1:8000/v1
